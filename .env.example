# Copy to .env and fill in your values. Variables set here are loaded by run.sh.
# Setting OPENAI_API_KEY automatically switches the provider to OpenAI — no need
# to set LLM_PROVIDER explicitly unless you want to force one direction.

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini       # or gpt-4o, o3-mini, etc.

# ── Ollama (local) ────────────────────────────────────────────────────────────
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen3.5:9b

# ── Override auto-detection ───────────────────────────────────────────────────
# LLM_PROVIDER=ollama           # force Ollama even if OPENAI_API_KEY is set
# LLM_PROVIDER=openai           # force OpenAI (OPENAI_API_KEY must be set)

# ── Concurrency (optional) ────────────────────────────────────────────────────
# LLM_CONCURRENCY=20            # default: 1 for Ollama, 20 for OpenAI
